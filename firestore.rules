rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Każdy zalogowany użytkownik czyta/pisze TYLKO swój dokument profilu.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Pod-kolekcje: profil fonetyczny, postępy, błędy Analityka
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
